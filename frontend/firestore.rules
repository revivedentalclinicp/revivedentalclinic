rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: authenticated users can read/write their own document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Appointments: user can only access their own appointments
    match /appointments/{appointmentId} {
      allow read, update, delete: if request.auth != null
        && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.userId;
    }

    // Records: user can only access their own records
    match /records/{recordId} {
      allow read, update, delete: if request.auth != null
        && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.userId;
    }

    // Public chatbot logs (optional, no auth required for reading)
    match /chatLogs/{logId} {
      allow create: if true;
      allow read: if request.auth != null;
    }
  }
}
